generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum SessionType {
  AUTOMATIC
  MANUAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  role          String    @default("MEMBER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  setupRequired Boolean   @default(false)
  memberProfile Member?
  sessions      Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Member {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  birthday      DateTime?
  gender        String?
  status        String        @default("ACTIVE")
  familyId      String?
  userId        String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  recruitedById String?
  attendance    Attendance[]
  family        Family?       @relation(fields: [familyId], references: [id])
  recruitedBy   Member?       @relation("Recruitment", fields: [recruitedById], references: [id])
  recruits      Member[]      @relation("Recruitment")
  user          User?         @relation(fields: [userId], references: [id])
  smartProfile  SmartProfile?
}

model SmartProfile {
  id        String   @id @default(cuid())
  slug      String   @unique
  bio       String?
  avatarUrl String?
  instagram String?
  twitter   String?
  linkedin  String?
  whatsapp  String?
  memberId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   Member[]
}

model Attendance {
  id        String          @id @default(cuid())
  date      DateTime
  serviceId String?
  eventId   String?
  memberId  String
  sessionId String?
  createdAt DateTime        @default(now())
  member    Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  session   ServiceSession? @relation(fields: [sessionId], references: [id])
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  location     String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isFeatured   Boolean  @default(false)
  recapContent String?
  recapImages  String[] @default([])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      DateTime
  imageUrl  String?
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShortLink {
  id        String   @id @default(cuid())
  slug      String   @unique
  url       String
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sermon {
  id                String   @id @default(cuid())
  title             String
  speaker           String
  series            String?
  description       String?
  videoUrl          String
  thumbnailUrl      String?
  date              DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  highlightQuote    String?
  highlightVideoUrl String?
}

model ServiceSession {
  id         String       @id @default(cuid())
  name       String
  date       DateTime     @db.Date
  startTime  DateTime
  endTime    DateTime
  headcount  Int          @default(0)
  isArchived Boolean      @default(false)
  type       SessionType  @default(AUTOMATIC)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]

  @@unique([name, date])
}

model HomeSlide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
